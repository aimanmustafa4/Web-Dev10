<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navbar</title>
    <style>
        * {
            margin: 0;
            padding: 0;
        }

        .navbar2 {
            display: flex;
            justify-content: space-between;
        }

        .list {
            padding: 10px;
        }

        .list ul {
            display: flex;
            /* justify-content: space-evenly; */
            padding: 10px;
        }

        .list ul li {
            list-style: none;
            padding: 10px;
        }

        .btns {
            margin-top: 25px;
            margin-right: 15px;
        }

        .btns input {
            padding: 6px;
            border-radius: 30px;
            border: 3px solid black;
            color: blueviolet;
        }

        .prime-btn {
            background-color: black;
            color: white;
            padding: 6px;
            border-radius: 30px;
        }
    </style>
</head>

<body>

    <div class="navbar1">
        <div class="icons">
            <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" fill="currentColor" class="bi bi-android"
                viewBox="0 0 16 16">
                <path
                    d="M2.76 3.061a.5.5 0 0 1 .679.2l1.283 2.352A8.9 8.9 0 0 1 8 5a8.9 8.9 0 0 1 3.278.613l1.283-2.352a.5.5 0 1 1 .878.478l-1.252 2.295C14.475 7.266 16 9.477 16 12H0c0-2.523 1.525-4.734 3.813-5.966L2.56 3.74a.5.5 0 0 1 .2-.678ZM5 10a1 1 0 1 0 0-2 1 1 0 0 0 0 2m6 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" fill="currentColor"
                class="bi bi-arrow-through-heart-fill" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                    d="M2.854 15.854A.5.5 0 0 1 2 15.5V14H.5a.5.5 0 0 1-.354-.854l1.5-1.5A.5.5 0 0 1 2 11.5h1.793l3.103-3.104a.5.5 0 1 1 .708.708L4.5 12.207V14a.5.5 0 0 1-.146.354zM16 3.5a.5.5 0 0 1-.854.354L14 2.707l-1.006 1.006c.236.248.44.531.6.845.562 1.096.585 2.517-.213 4.092-.793 1.563-2.395 3.288-5.105 5.08L8 13.912l-.276-.182A24 24 0 0 1 5.8 12.323L8.31 9.81a1.5 1.5 0 0 0-2.122-2.122L3.657 10.22a9 9 0 0 1-1.039-1.57c-.798-1.576-.775-2.997-.213-4.093C3.426 2.565 6.18 1.809 8 3.233c1.25-.98 2.944-.928 4.212-.152L13.292 2 12.147.854A.5.5 0 0 1 12.5 0h3a.5.5 0 0 1 .5.5z" />
            </svg>
        </div>

        <div class="items">
            <b>Find a store | Help | Join Us | Sign in</b>
        </div>
    </div>




    <div class="navbar2">
        <div class="logo">
            <img src="data/images-removebg-preview.png" alt="logo" width="100px">
        </div>
        <div class="list">
            <ul>
                <li>Men</li>
                <li>Women</li>
                <li>Kids</li>
                <li>Jordan</li>
                <li>NikeSKIMS</li>
                <li>Sports</li>
            </ul>
        </div>
        <div class="btns">
            <input type="search" placeholder="Search">
            <button class="prime-btn">Login|Signup</button>
        </div>
    </div>
</body>

</html>
